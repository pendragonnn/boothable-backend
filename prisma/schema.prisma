generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN     @map("admin")
  ORGANIZER @map("organizer")
  VENDOR    @map("vendor")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  name         String    @db.VarChar(150)
  email        String    @unique @db.VarChar(150)
  phone        String?   @db.VarChar(30)
  password     String    @db.VarChar(255)
  role         Role      @default(VENDOR)
  refreshToken String?   @map("refresh_token") @db.Text
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

  events   Event[]
  bookings Booking[]

  @@map("users")
}

model Event {
  id            String    @id @default(uuid()) @db.Uuid
  eventName     String    @map("event_name") @db.VarChar(200)
  organizerId   String?   @map("organizer_id") @db.Uuid
  location      String?   @db.VarChar(255)
  startDate     DateTime? @map("start_date") @db.Date
  endDate       DateTime? @map("end_date") @db.Date
  description   String?   @db.Text
  eventBoothMap String?   @map("event_booth_map") @db.VarChar(255)
  paymentVa     String?   @map("payment_va") @db.VarChar(255)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

  organizer User?   @relation(fields: [organizerId], references: [id])
  booths    Booth[]

  @@map("events")
}

enum BoothStatus {
  AVAILABLE   @map("available")
  BOOKED      @map("booked")
  UNAVAILABLE @map("unavailable")
}

model Booth {
  id                 String      @id @default(uuid()) @db.Uuid
  eventId            String?     @map("event_id") @db.Uuid
  boothCode          String      @map("booth_code") @db.VarChar(50)
  type               String?     @db.VarChar(100)
  size               String?     @db.VarChar(50)
  pricePerDay        Decimal     @map("price_per_day") @db.Decimal(10, 2)
  status             BoothStatus @default(AVAILABLE)
  availableStartDate DateTime    @map("available_start_date") @db.Date
  availableEndDate   DateTime    @map("available_end_date") @db.Date
  description        String?     @db.Text
  createdAt          DateTime?   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime?   @updatedAt @map("updated_at") @db.Timestamp(6)

  event    Event?    @relation(fields: [eventId], references: [id])
  bookings Booking[]

  @@map("booths")
}

enum BookingStatus {
  PENDING         @map("Pending")
  WAITING_PAYMENT @map("Waiting Payment")
  PROCESSING      @map("Processing")
  APPROVED        @map("Approved")
  REJECTED        @map("Rejected")
  CANCELLED       @map("Cancelled")
}

model Booking {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String?       @map("user_id") @db.Uuid
  boothId         String?       @map("booth_id") @db.Uuid
  rentalStartDate DateTime      @map("rental_start_date") @db.Date
  rentalEndDate   DateTime      @map("rental_end_date") @db.Date
  status          BookingStatus @default(PENDING)
  totalPrice      BigInt        @map("total_price")
  createdAt       DateTime?     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime?     @updatedAt @map("updated_at") @db.Timestamp(6)

  user     User?    @relation(fields: [userId], references: [id])
  booth    Booth?   @relation(fields: [boothId], references: [id])
  payments Payment?

  @@map("bookings")
}

enum PaymentMethod {
  BANK_TRANSFER @map("Bank Transfer")
}

enum PaymentStatus {
  UNPAID               @map("Unpaid")
  WAITING_VERIFICATION @map("Waiting Verification")
  PAID                 @map("Paid")
  REJECTED             @map("Rejected")
}

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  bookingId     String        @unique @map("booking_id") @db.Uuid
  paymentMethod PaymentMethod @default(BANK_TRANSFER) @map("payment_method")
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")
  paymentProof  String?       @map("payment_proof") @db.VarChar(255)
  createdAt     DateTime?     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime?     @updatedAt @map("updated_at") @db.Timestamp(6)

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("payments")
}
